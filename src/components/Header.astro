---
import type { Locale } from '../i18n/config';
import { LOCALES, LOCALE_NAMES } from '../i18n/config';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);
---

<header class="sticky top-0 z-30 border-b border-white/5 bg-ink-950/70 backdrop-blur-md">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 h-14 flex items-center gap-6">
    <a href={`/${locale}/`} class="flex items-center gap-2 font-semibold text-white">
      <span class="inline-block w-7 h-7 rounded-lg gradient-bg shadow-md shadow-brand-purple/30"></span>
      <span class="text-lg tracking-tight">unflick</span>
    </a>

    <nav class="ml-auto hidden md:flex items-center gap-6 text-sm text-zinc-300">
      <a href={`/${locale}/#features`} class="hover:text-white transition">{s.nav.features}</a>
      <a href={`/${locale}/docs/`} class="hover:text-white transition">{s.nav.docs}</a>
      <a href={`/${locale}/#download`} class="hover:text-white transition">{s.nav.download}</a>
      <a href="https://github.com/zhitongblog/unflick" target="_blank" rel="noopener" class="hover:text-white transition">
        {s.nav.github}
      </a>
    </nav>

    <div class="ml-auto md:ml-0 relative">
      <details class="group">
        <summary class="list-none cursor-pointer text-sm text-zinc-400 hover:text-white transition flex items-center gap-1.5 select-none">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm-1.66-6.45c-.06-.39-.1-.79-.1-1.1 0-.32.04-.71.1-1.1h3.32c.06.39.1.79.1 1.1s-.04.71-.1 1.1H8.34Zm.42 1.5h2.48a6.5 6.5 0 0 1-1.24 2.4 6.5 6.5 0 0 1-1.24-2.4Zm-2.04 0c.27.99.69 1.91 1.23 2.7A6.51 6.51 0 0 1 4.5 13.05h2.22Zm6.6 0h2.22a6.51 6.51 0 0 1-3.45 2.7c.54-.79.96-1.71 1.23-2.7Zm2.74-1.5h-2.43c.06-.39.09-.79.09-1.1s-.03-.71-.09-1.1h2.43c.13.36.2.73.2 1.1s-.07.74-.2 1.1Zm-9.4 0H4.23a3.51 3.51 0 0 1 0-2.2h2.43c-.06.39-.09.79-.09 1.1s.03.71.09 1.1Zm.5-3.6a8 8 0 0 1 1.24-2.4 8 8 0 0 1 1.24 2.4H8.16Zm-1.44 0H4.5a6.51 6.51 0 0 1 3.45-2.7c-.54.79-.96 1.71-1.23 2.7Zm6.56 0c-.27-.99-.69-1.91-1.23-2.7a6.51 6.51 0 0 1 3.45 2.7h-2.22Z" clip-rule="evenodd" />
          </svg>
          <span>{LOCALE_NAMES[locale]}</span>
        </summary>
        <div class="absolute right-0 mt-2 w-44 rounded-xl border border-zinc-800 bg-ink-900/95 backdrop-blur-md shadow-xl py-1 z-40">
          {LOCALES.map((l) => (
            <a
              href={`/${l}/`}
              class={`block px-4 py-2 text-sm hover:bg-white/5 ${l === locale ? 'text-white' : 'text-zinc-400'}`}
            >
              {LOCALE_NAMES[l]}
            </a>
          ))}
        </div>
      </details>
    </div>
  </div>
</header>
