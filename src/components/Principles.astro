---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);
const p = s.principles;

// Four pillars rendered as a high-contrast grid right under the hero. The
// goal is a single glance: "this player won't extract anything from me."
// Spotify / many other apps have inverted users' expectations of what a
// "free" media player looks like — we lead with the negation up front.
const pillars = [
  { key: 'free', icon: 'price' },
  { key: 'noLogin', icon: 'user' },
  { key: 'noAds', icon: 'shield' },
  { key: 'local', icon: 'lock' },
] as const;
---

<section class="border-t border-white/5 py-16 sm:py-20 bg-gradient-to-b from-brand-purple/[0.04] to-transparent">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
        <span class="gradient-text">{p.title}</span>
      </h2>
      <p class="mt-3 text-zinc-400 max-w-xl mx-auto">{p.subtitle}</p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      {pillars.map((pillar) => {
        const item = p[pillar.key as keyof typeof p] as { title: string; body: string };
        return (
          <div class="card flex flex-col gap-3 hover:border-brand-purple/30 transition-colors">
            <div class="w-10 h-10 rounded-lg gradient-bg/20 bg-gradient-to-br from-brand-purple/20 to-brand-pink/10 ring-1 ring-brand-purple/30 flex items-center justify-center text-brand-purple">
              {pillar.icon === 'price' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23" />
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg>
              )}
              {pillar.icon === 'user' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                  <line x1="3" y1="3" x2="21" y2="21" stroke-width="1.5" />
                </svg>
              )}
              {pillar.icon === 'shield' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <line x1="9" y1="9" x2="15" y2="15" />
                  <line x1="15" y1="9" x2="9" y2="15" />
                </svg>
              )}
              {pillar.icon === 'lock' && (
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
              )}
            </div>
            <h3 class="text-base sm:text-lg font-semibold text-white">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.body}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
