---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);

const items = [
  {
    icon: 'monitor',
    title: s.features.gui.title,
    body: s.features.gui.body,
  },
  {
    icon: 'terminal',
    title: s.features.cli.title,
    body: s.features.cli.body,
  },
  {
    icon: 'spark',
    title: s.features.mcp.title,
    body: s.features.mcp.body,
  },
];
---

<section id="features" class="py-20 sm:py-28 border-t border-white/5">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">{s.features.title}</h2>
      <p class="mt-4 text-zinc-400 max-w-2xl mx-auto">{s.features.subtitle}</p>
    </div>

    <div class="grid sm:grid-cols-3 gap-5">
      {items.map((item) => (
        <div class="card hover:border-zinc-700 transition">
          <div class="w-10 h-10 rounded-lg gradient-bg flex items-center justify-center shadow-md shadow-brand-purple/30">
            {item.icon === 'monitor' && (
              <svg class="w-5 h-5 text-white" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 .75.75v9a.75.75 0 0 1-.75.75h-5.5l.5 1.75H14a.75.75 0 0 1 0 1.5H6a.75.75 0 0 1 0-1.5h1.75l.5-1.75H2.75a.75.75 0 0 1-.75-.75v-9Zm1.5.75v7.5h13V5.5h-13Z" clip-rule="evenodd"/></svg>
            )}
            {item.icon === 'terminal' && (
              <svg class="w-5 h-5 text-white" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 .75.75v10.5a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1-.75-.75V4.75ZM3.5 5.5v9h13v-9h-13Zm2.32 2.45a.75.75 0 0 1 1.06.02l2.25 2.5a.75.75 0 0 1 0 1.06l-2.25 2.5a.75.75 0 1 1-1.12-1l1.8-2-1.8-2a.75.75 0 0 1 .06-1.08Zm4.18 4.55a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 0 1.5h-3a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd"/></svg>
            )}
            {item.icon === 'spark' && (
              <svg class="w-5 h-5 text-white" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5a.75.75 0 0 1 .7.5l1.34 3.59 3.59 1.34a.75.75 0 0 1 0 1.4l-3.59 1.34-1.34 3.59a.75.75 0 0 1-1.4 0L7.96 9.67 4.37 8.33a.75.75 0 0 1 0-1.4L7.96 5.6 9.3 2A.75.75 0 0 1 10 1.5Zm5.25 11a.75.75 0 0 1 .7.49l.6 1.6 1.6.6a.75.75 0 0 1 0 1.4l-1.6.6-.6 1.6a.75.75 0 0 1-1.4 0l-.6-1.6-1.6-.6a.75.75 0 0 1 0-1.4l1.6-.6.6-1.6a.75.75 0 0 1 .7-.49Z"/></svg>
            )}
          </div>
          <h3 class="mt-5 text-lg font-semibold text-white">{item.title}</h3>
          <p class="mt-2 text-sm text-zinc-400 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
