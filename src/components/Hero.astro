---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/utils';
import stats from '../data/stats.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);

function formatDownloads(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return n.toString();
}

const initialStars = stats.stars;
const initialDownloads = stats.downloads;
// Derive the headline version from whatever the build-time stats grab pulled.
// Falls through to a hardcoded value only if the stats fetch was unable to
// resolve a release (offline build, fresh repo with no releases, etc).
const versionLabel = (stats as { latest_tag?: string | null }).latest_tag ?? 'v0.8.0';
---

<section class="relative overflow-hidden">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 pt-20 pb-24 sm:pt-32 sm:pb-36 text-center">
    <div class="inline-flex flex-wrap items-center justify-center gap-x-2.5 gap-y-1 px-3.5 py-1.5 rounded-full text-xs font-medium text-zinc-300 bg-white/5 border border-white/10 mb-8">
      <span class="inline-flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full gradient-bg animate-pulse"></span>
        {versionLabel}
      </span>
      <span class="text-zinc-600">·</span>
      <span>MIT</span>
      <span class="text-zinc-600">·</span>
      <span class="inline-flex items-center gap-1">
        <svg class="w-3 h-3 text-amber-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M9.05 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 0 0 .95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 0 0-.363 1.118l1.518 4.674c.3.921-.755 1.688-1.539 1.118l-3.976-2.888a1 1 0 0 0-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.539-1.118l1.518-4.674a1 1 0 0 0-.363-1.118L2.075 10.1c-.783-.57-.38-1.81.588-1.81h4.915a1 1 0 0 0 .951-.69l1.518-4.674Z"/>
        </svg>
        <span id="hero-stars">{initialStars}</span>
      </span>
      <span class="text-zinc-600">·</span>
      <span>
        <span id="hero-downloads">{formatDownloads(initialDownloads)}</span> downloads
      </span>
    </div>

    <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05]">
      <span class="gradient-text">{s.hero.headline}</span>
    </h1>

    <p class="mt-6 sm:mt-8 text-lg sm:text-xl text-zinc-300 max-w-3xl mx-auto leading-relaxed">
      {s.hero.subhead}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
      <a href="#download" class="btn-primary">
        <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.6L6.3 8.4a.75.75 0 1 0-1.1 1.02l4.25 4.6a.75.75 0 0 0 1.1 0l4.25-4.6a.75.75 0 1 0-1.1-1.02l-2.95 3.2v-8.85Z" />
          <path d="M3.5 14a.75.75 0 0 1 .75.75v1.25c0 .14.11.25.25.25h11a.25.25 0 0 0 .25-.25V14.75a.75.75 0 0 1 1.5 0V16a1.75 1.75 0 0 1-1.75 1.75H4.5A1.75 1.75 0 0 1 2.75 16V14.75A.75.75 0 0 1 3.5 14Z" />
        </svg>
        {s.hero.primaryCta}
      </a>
      <a
        href="https://github.com/zhitongblog/unflick"
        target="_blank"
        rel="noopener"
        class="btn-secondary"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58 0-.29-.01-1.05-.02-2.06-3.34.73-4.04-1.61-4.04-1.61-.55-1.4-1.34-1.78-1.34-1.78-1.1-.75.08-.74.08-.74 1.21.09 1.85 1.25 1.85 1.25 1.08 1.85 2.83 1.31 3.52 1 .11-.78.42-1.31.77-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.31-.54-1.53.11-3.18 0 0 1.01-.32 3.31 1.23a11.5 11.5 0 0 1 6.02 0c2.3-1.55 3.31-1.23 3.31-1.23.65 1.65.24 2.87.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.28 0 .32.21.7.83.58A12 12 0 0 0 12 .5Z" />
        </svg>
        {s.hero.secondaryCta}
      </a>
    </div>
  </div>
</section>

<script is:inline>
  // Live-refresh GitHub stats. The page already SSRs build-time numbers so
  // the badge isn't blank if this fails — we just leave the static values.
  fetch('/api/stats')
    .then((r) => (r.ok ? r.json() : null))
    .then((s) => {
      if (!s || typeof s.stars !== 'number') return;
      var starsEl = document.getElementById('hero-stars');
      var dlEl = document.getElementById('hero-downloads');
      if (starsEl && s.stars > 0) starsEl.textContent = s.stars.toString();
      if (dlEl && typeof s.downloads === 'number' && s.downloads > 0) {
        dlEl.textContent = s.downloads >= 1000
          ? (s.downloads / 1000).toFixed(1).replace(/\.0$/, '') + 'k'
          : s.downloads.toString();
      }
    })
    .catch(function () { /* keep static values */ });
</script>
