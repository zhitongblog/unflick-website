---
import type { Locale } from '../i18n/config';
import { t } from '../i18n/utils';
import stats from '../data/stats.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);

// Pin the download link to the exact tag stats.json captured at build time,
// so the file name (e.g. unflick-ai_0.8.1_x64-setup.exe) always matches the
// asset that GitHub actually has. /releases/latest/download works for the
// latest tag but breaks if anyone visits an older URL or shares a permalink.
const tag = (stats as { latest_tag?: string | null }).latest_tag ?? 'v0.8.1';
const tagBare = tag.replace(/^v/, '');
const RELEASE = `https://github.com/zhitongblog/unflick/releases/download/${tag}`;
---

<section id="download" class="py-20 sm:py-28 border-t border-white/5">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">{s.download.title}</h2>
      <p class="mt-3 text-zinc-400">{s.download.subtitle}</p>
      <p class="mt-2 text-xs text-zinc-500 font-mono">{tag}</p>
    </div>

    <!-- Windows -->
    <div class="mb-10">
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-4 h-4 text-zinc-400" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3 5.483l7.83-1.066V11.5H3V5.483zm0 13.034V12.5h7.83v7.083L3 18.517zM11.83 11.5h9.17V3l-9.17 1.25V11.5zm0 8.25l9.17 1.25V12.5h-9.17v7.25z"/>
        </svg>
        <h3 class="text-sm font-semibold tracking-wide text-zinc-300">Windows 10 / 11 · x64</h3>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        <!-- Standard -->
        <div class="card flex flex-col">
          <div class="flex items-center justify-between">
            <h4 class="text-xl font-semibold text-white">{s.download.standard.name}</h4>
            <span class="text-xs text-zinc-500 font-mono">{s.download.standard.size}</span>
          </div>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed flex-1">{s.download.standard.blurb}</p>
          <a
            href={`${RELEASE}/unflick_${tagBare}_x64-setup-standard.exe`}
            class="btn-secondary mt-6 w-full justify-center"
          >
            {s.download.standard.cta}
          </a>
          <a
            href={`${RELEASE}/unflick_${tagBare}_x64_en-US-standard.msi`}
            class="mt-2 text-center text-[11px] text-zinc-500 hover:text-zinc-300 transition font-mono"
          >
            .msi (admin install)
          </a>
        </div>

        <!-- AI (recommended) -->
        <div class="card flex flex-col relative border-brand-purple/40 bg-gradient-to-br from-brand-purple/10 to-transparent">
          <span class="absolute -top-3 left-6 px-2.5 py-0.5 rounded-full text-[10px] uppercase font-bold tracking-wider gradient-bg text-white">
            {s.download.ai.badge}
          </span>
          <div class="flex items-center justify-between">
            <h4 class="text-xl font-semibold text-white">{s.download.ai.name}</h4>
            <span class="text-xs text-zinc-500 font-mono">{s.download.ai.size}</span>
          </div>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed flex-1">{s.download.ai.blurb}</p>
          <a
            href={`${RELEASE}/unflick-ai_${tagBare}_x64-setup.exe`}
            class="btn-primary mt-6 w-full"
          >
            {s.download.ai.cta}
          </a>
          <a
            href={`${RELEASE}/unflick-ai_${tagBare}_x64_en-US.msi`}
            class="mt-2 text-center text-[11px] text-white/40 hover:text-white/70 transition font-mono"
          >
            .msi (admin install)
          </a>
        </div>
      </div>
      <!-- SmartScreen heads-up — Windows installers aren't EV-signed yet. -->
      <div class="mt-4 rounded-lg border border-amber-400/20 bg-amber-400/5 px-4 py-3 text-[12px] leading-relaxed text-amber-200/80">
        <strong class="text-amber-200">Heads up — </strong>
        The Windows installers aren't code-signed yet, so SmartScreen may flash "unrecognized app." Click <em>More info</em> → <em>Run anyway</em>. Source is on GitHub if you want to audit before running.
      </div>
    </div>

    <!-- macOS -->
    <div>
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-4 h-4 text-zinc-400" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83zM13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <h3 class="text-sm font-semibold tracking-wide text-zinc-300">macOS 11+ · Apple Silicon</h3>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        <div class="card flex flex-col">
          <div class="flex items-center justify-between">
            <h4 class="text-xl font-semibold text-white">{s.download.mac.name}</h4>
            <span class="text-xs text-zinc-500 font-mono">{s.download.mac.size}</span>
          </div>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed flex-1">{s.download.mac.blurb}</p>
          <a
            href={`${RELEASE}/unflick_${tagBare}_aarch64.dmg`}
            class="btn-secondary mt-6 w-full justify-center"
          >
            {s.download.mac.cta}
          </a>
          <p class="mt-3 text-[11px] text-zinc-500 leading-relaxed">
            <strong class="text-zinc-400">Prerequisite:</strong> <code class="font-mono text-amber-300/90">brew install mpv</code> — unflick loads libmpv at runtime from your Homebrew install.
          </p>
        </div>
        <div class="card flex flex-col items-center justify-center text-center text-[13px] text-zinc-500 leading-relaxed border-dashed">
          <p class="font-medium text-zinc-400">{s.download.mac.intelTitle}</p>
          <p class="mt-2">{s.download.mac.intelBody}</p>
        </div>
      </div>
    </div>

    <p class="mt-10 text-center text-[11px] text-zinc-500">
      Linux port tracked for v0.8.x — see
      <a href="https://github.com/zhitongblog/unflick/milestones" target="_blank" rel="noopener" class="underline hover:text-zinc-300">milestones</a>.
    </p>

    <div class="text-center mt-8">
      <a
        href="https://github.com/zhitongblog/unflick"
        target="_blank"
        rel="noopener"
        class="text-sm text-zinc-400 hover:text-white transition"
      >
        {s.download.github}
      </a>
    </div>
  </div>
</section>
